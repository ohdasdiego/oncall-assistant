# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-random-string
DB_PATH=/var/lib/oncall-assistant/oncall.db

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── ADOStack integrations ──────────────────────────────────────────────────────
RAG_RUNBOOK_URL=https://runbooks.ado-runner.com/query
INCIDENT_LOGGER_URL=http://localhost:5001/api/incidents
INFRA_MONITOR_URL=http://localhost:5000/api/metrics

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Webhooks ──────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change-me-in-prod

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL for Telegram link generation
BASE_URL=https://oncall.ado-runner.com

# Timeout (seconds) for each context source fetch
CONTEXT_TIMEOUT_SECONDS=8
